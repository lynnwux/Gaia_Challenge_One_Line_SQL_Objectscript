ROUTINE RunScript
 d ##class(%File).Delete("/home/irisowner/dev/data/out/variable_objects.csv") s f=##class(%Stream.FileCharacter).%New(),f.Filename="/home/irisowner/dev/data/out/variable_objects.csv" d f.WriteLine("source_id,bp_min_flux,bp_max_flux,rp_min_flux,rp_max_flux,percentage_change") s rs=##class(%SQL.Statement).%ExecDirect(,"SELECT id,n,x,p,q,CASE WHEN(x-n)/n>=(q-p)/p THEN(x-n)/n*100 ELSE(q-p)/p*100 END FROM g WHERE(x-n)/n*100>100 OR(q-p)/p*100>100") while rs.%Next(){d f.WriteLine(rs.%GetData(1)_","_rs.%GetData(2)_","_rs.%GetData(3)_","_rs.%GetData(4)_","_rs.%GetData(5)_","_rs.%GetData(6))} d f.%Save()
