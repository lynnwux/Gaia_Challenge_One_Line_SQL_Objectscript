ROUTINE RunScript
 d ##class(%SYS.Python).Run("import glob,re,sys,isal.igzip as ig;sys.path.insert(0,\x27/usr/irissys/lib/python\x27);import iris;R=re.compile(rb\x27^\d+,(\d+),\d+,(?:\x22[^\x22]*\x22,){8}\x22(\[[^\]]*\])\x22,(?:\x22[^\x22]*\x22,){4}\x22(\[[^\]]*\])\x22\x27);NaN=b\x27NaN\x27;open(\x27/tmp/g.csv\x27,\x27w\x27).writelines(f\x27{m.group(1).decode()},{b},{v.decode()*(v!=NaN)}\n\x27 for gz in sorted(glob.glob(\x27/home/irisowner/dev/data/in/*.csv.gz\x27)) for line in ig.decompress(open(gz,\x27rb\x27).read()).split(b\x27\n\x27) if line and line[:1] not in(b\x27#\x27,b\x27s\x27,b\x27n\x27) for m in[R.match(line)] if m for b,a in((0,m.group(2)),(1,m.group(3))) for v in[s.strip() for s in a[1:-1].split(b\x27,\x27)] if v);iris.sql.exec(\x27DROP TABLE IF EXISTS g\x27);iris.sql.exec(\x27CREATE TABLE g(id BIGINT,b TINYINT,f FLOAT)\x27);iris.sql.exec(\x27LOAD DATA FROM FILE \x27\x27/tmp/g.csv\x27\x27 INTO g(id,b,f)\x27)") s f=##class(%Stream.FileCharacter).%New(),f.Filename="/home/irisowner/dev/data/out/variable_objects.csv" d f.WriteLine("source_id,bp_min_flux,bp_max_flux,rp_min_flux,rp_max_flux,percentage_change") s r=##class(%SQL.Statement).%ExecDirect(,"SELECT source_id,bp_min_flux,bp_max_flux,rp_min_flux,rp_max_flux,CASE WHEN (bp_max_flux-bp_min_flux)/bp_min_flux>=(rp_max_flux-rp_min_flux)/rp_min_flux THEN (bp_max_flux-bp_min_flux)/bp_min_flux*100 ELSE (rp_max_flux-rp_min_flux)/rp_min_flux*100 END percentage_change FROM(SELECT id source_id,MIN(CASE WHEN b=0 THEN f END) bp_min_flux,MAX(CASE WHEN b=0 THEN f END) bp_max_flux,MIN(CASE WHEN b=1 THEN f END) rp_min_flux,MAX(CASE WHEN b=1 THEN f END) rp_max_flux FROM g GROUP BY id)WHERE(bp_max_flux-bp_min_flux)/bp_min_flux*100>100 OR(rp_max_flux-rp_min_flux)/rp_min_flux*100>100") while r.%Next(){d f.WriteLine(r.%GetData(1)_","_r.%GetData(2)_","_r.%GetData(3)_","_r.%GetData(4)_","_r.%GetData(5)_","_r.%GetData(6))} d f.%Save()
