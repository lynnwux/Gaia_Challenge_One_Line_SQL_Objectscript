ROUTINE LoadGaia
 do ##class(%SYS.Python).Run("import glob,re,sys;sys.path.insert(0,'/usr/irissys/lib/python');import iris;R=re.compile(b'^\\d+,(\\d+),\\d+,(?:\x22[^\x22]*\x22,){8}\x22(\\[[^\\]]*\\])\x22,(?:\x22[^\x22]*\x22,){4}\x22(\\[[^\\]]*\\])\x22');open('/tmp/g.csv','w').writelines('{},{},{}\n'.format(m.group(1).decode(),b,'0' if v.strip()==b'NaN' else v.strip().decode()) for p in sorted(glob.glob('/tmp/gaia_data/*.csv')) for l in open(p,'rb').read().split(b'\n') for m in [R.match(l)] if m for b,a in((0,m.group(2)),(1,m.group(3))) for v in a[1:-1].split(b',') if v.strip());exec('try:\n  iris.sql.exec(\x27DROP TABLE g\x27)\nexcept:\n  pass');iris.sql.exec('CREATE TABLE g(id BIGINT,b TINYINT,f FLOAT)');iris.sql.exec('LOAD DATA FROM FILE \'/tmp/g.csv\' INTO g(id,b,f)')")
 Quit
